{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
  },
  "include": [
    "src/*.ts",
    "src/**/*.ts"
  ]
}