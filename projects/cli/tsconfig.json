{
  "compilerOptions": {
    "declaration": true,
    "module": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@fullstory/activation-sdk/*": [
        "../sdk/dist/*"
      ],
    }
  },
  "include": [
    "./src/**/*",
  ],
  "ts-node": {
    "esm": true
  },
  "references": [
    {
      "path": "../sdk"
    },
  ]
}